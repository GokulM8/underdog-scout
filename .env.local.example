# football-data.org free-tier API key — https://www.football-data.org/client/register
NEXT_PUBLIC_FOOTBALL_DATA_API_KEY=

# Groq API key for match predictions, nation briefs, and hidden hero finder (llama-3.3-70b-versatile) — https://console.groq.com/keys
GROQ_API_KEY=

# Python interpreter with `docling` + `reportlab` installed, used by /api/generate-report
# to build the downloadable scout report PDF. Defaults to "python3" on PATH.
DOCLING_PYTHON_BIN=

# Supabase project (for storing team data and match results)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
